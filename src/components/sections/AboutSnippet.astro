---
import { SITE } from '@lib/constants';
---

<section class="py-16 sm:py-20 bg-surface/40" aria-label="About the crafter">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
      <div class="flex-shrink-0 group perspective-1000" data-reveal="left">
        <div class="relative w-56 sm:w-72 mx-auto">
          <!-- Decorative background layers -->
          <div class="absolute inset-0 bg-primary/20 rounded-3xl translate-x-3 translate-y-3 rotate-3 transition-transform duration-500 ease-out group-hover:translate-x-4 group-hover:translate-y-4 group-hover:rotate-6 shadow-sm"></div>
          <div class="absolute inset-0 bg-gold/10 rounded-3xl -translate-x-2 -translate-y-2 -rotate-2 transition-transform duration-500 ease-out group-hover:-translate-x-3 group-hover:-translate-y-3 group-hover:-rotate-4 shadow-sm"></div>
          
          <!-- Main Photo Frame -->
          <div class="relative w-full bg-body p-3 sm:p-4 rounded-3xl shadow-xl shadow-primary/10 -rotate-2 transition-transform duration-500 ease-out group-hover:rotate-0 border border-surface flex flex-col z-10 box-border bg-white">
            <!-- Washi Tape piece -->
            <div class="absolute -top-3 right-4 w-16 h-5 bg-lavender/60 border border-white/40 shadow-sm rotate-6 z-20 backdrop-blur-md opacity-90" style="clip-path: polygon(2% 10%, 98% 0%, 100% 90%, 0% 100%);"></div>

            <div class="relative aspect-square rounded-2xl overflow-hidden bg-surface shadow-inner">
              <img
                src="/faith.jpg"
                alt="Faith, the crafter behind Faithfully Crafted"
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 border border-black/5 rounded-2xl pointer-events-none mix-blend-overlay"></div>
            </div>
            
            <!-- Frame Caption -->
            <div class="pt-3 pb-1 text-center pointer-events-none">
              <span class="font-brand text-2xl text-primary-bold/90 drop-shadow-sm">Hello there!</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1 text-center lg:text-left" data-reveal="right">
        <h2 class="font-heading text-3xl sm:text-4xl font-700 text-text">
          Meet <span class="font-brand text-primary-bold">{SITE.crafter}</span>
        </h2>
        <p class="mt-4 text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0">
          Hi, I'm Faith! What started with a gift of crochet hooks from my boyfriend turned into a
          passion I never expected. My very first creation was a little bee — and from that moment,
          I was hooked. With the support of my family and friends, Faithfully Crafted was born in
          late 2024.
        </p>
        <p class="mt-3 text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0">
          Based in {SITE.location}, I turn colorful yarn into amigurumi, keychains, and custom gifts
          — each one made faithfully, with love in every stitch.
        </p>
        <a
          href="/about/"
          class="inline-flex items-center gap-2 mt-6 font-heading font-600 text-primary-bold hover:text-lavender transition-colors"
        >
          Read my story
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
