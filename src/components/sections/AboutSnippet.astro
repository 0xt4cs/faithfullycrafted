---
import { SITE } from '@lib/constants';
---

<section class="py-16 sm:py-20 bg-surface/40" aria-label="About the crafter">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
      <!-- Image/Illustration -->
      <div class="flex-shrink-0" data-reveal="left">
        <div class="w-56 h-56 sm:w-72 sm:h-72 rounded-full bg-gradient-to-br from-primary/15 via-cream to-lavender/15 flex items-center justify-center shadow-lg shadow-primary/10">
          <div class="text-center">
            <svg class="w-20 h-20 mx-auto text-primary-bold/40" viewBox="0 0 80 80" fill="currentColor">
              <circle cx="40" cy="30" r="18" />
              <path d="M15 70c0-15 12-25 25-25s25 10 25 25" />
            </svg>
            <p class="mt-2 text-xs text-text-muted italic">Photo coming soon</p>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="flex-1 text-center lg:text-left" data-reveal="right">
        <h2 class="font-heading text-3xl sm:text-4xl font-700 text-text">
          Meet <span class="font-brand text-primary-bold">{SITE.crafter}</span>
        </h2>
        <p class="mt-4 text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0">
          Hi there! I'm Faith, the heart and hands behind Faithfully Crafted. What started as a
          small hobby has grown into a passion — creating beautiful crochet pieces that bring joy to
          people's lives. Every stitch is made with love, patience, and a whole lot of yarn!
        </p>
        <p class="mt-3 text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0">
          Based in {SITE.location}, I specialize in amigurumi, accessories, and custom handmade
          gifts perfect for every occasion.
        </p>
        <a
          href="/about/"
          class="inline-flex items-center gap-2 mt-6 font-heading font-600 text-primary-bold hover:text-lavender transition-colors"
        >
          Read my story
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
