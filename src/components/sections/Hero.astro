---
import Button from '@components/ui/Button.astro';
import { SITE, SOCIALS } from '@lib/constants';
---

<section class="relative overflow-hidden bg-gradient-to-b from-cream via-surface to-background" aria-label="Welcome to Faithfully Crafted">
  <!-- Decorative floating elements -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Yarn ball top-right -->
    <svg
      class="absolute -top-4 right-8 w-20 h-20 text-mint/30 animate-float hidden sm:block"
      viewBox="0 0 80 80"
      fill="currentColor"
    >
      <circle cx="40" cy="40" r="35" />
      <path d="M20 50c10-15 20-20 25-35M30 20c5 15 15 25 30 30" stroke="white" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.5" />
    </svg>
    <!-- Bow left -->
    <svg
      class="absolute top-1/3 -left-2 w-14 h-14 text-primary/20 animate-float-delayed hidden lg:block"
      viewBox="0 0 56 56"
      fill="currentColor"
    >
      <path d="M28 28c-8-8-20-12-20-4s12 12 20 4zm0 0c8-8 20-12 20-4s-12 12-20 4z" />
      <circle cx="28" cy="28" r="4" />
    </svg>
    <!-- Small stars -->
    <svg
      class="absolute bottom-1/4 right-1/4 w-6 h-6 text-gold/40 animate-pulse-soft"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d="M12 0L14 9L24 12L14 14L12 24L10 14L0 12L10 9Z" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-28">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
      <!-- Text Content -->
      <div class="flex-1 text-center lg:text-left" data-reveal="up">
        <h1
          class="font-brand text-primary-bold leading-tight"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
        >
          {SITE.name}
        </h1>
        <p
          class="mt-4 font-heading text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0"
          style="font-size: clamp(1.1rem, 2vw, 1.35rem);"
        >
          {SITE.tagline}
        </p>
        <p class="mt-3 text-text-muted/80 max-w-md mx-auto lg:mx-0">
          Beautiful handmade crochet pieces — amigurumi, accessories, and heartfelt gifts, crafted
          by Faith from the Philippines.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <Button href="/gallery/" variant="primary" size="lg">
            View Gallery
          </Button>
          <Button href={SOCIALS.facebook.messenger} variant="secondary" size="lg" external>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 4.974 0 11.111c0 3.498 1.744 6.614 4.469 8.654V24l4.088-2.242c1.092.3 2.246.464 3.443.464 6.627 0 12-4.975 12-11.111S18.627 0 12 0z" />
            </svg>
            Message Me
          </Button>
        </div>
      </div>

      <!-- Decorative Mascot Area -->
      <div class="flex-shrink-0 relative" data-reveal="scale">
        <div class="w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96 rounded-full bg-gradient-to-br from-primary/20 via-surface to-lavender/20 flex items-center justify-center shadow-xl shadow-primary/10">
          <div class="text-center p-8">
            <svg class="w-24 h-24 sm:w-32 sm:h-32 mx-auto text-primary-bold animate-spin-slow" viewBox="0 0 100 100" fill="currentColor">
              <circle cx="50" cy="50" r="40" opacity="0.15" />
              <circle cx="50" cy="50" r="30" opacity="0.1" />
              <circle cx="50" cy="50" r="20" fill="currentColor" opacity="0.2" />
              <path d="M25 60c10-20 20-25 25-45M35 15c8 20 17 30 35 40" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.3" />
            </svg>
            <p class="mt-4 font-brand text-primary-bold text-xl sm:text-2xl">by Faith</p>
          </div>
        </div>
        <!-- Floating mini yarn balls -->
        <div class="absolute -top-4 -right-4 w-10 h-10 bg-mint/40 rounded-full animate-float"></div>
        <div class="absolute -bottom-2 -left-4 w-8 h-8 bg-lavender/40 rounded-full animate-float-delayed"></div>
      </div>
    </div>
  </div>

  <!-- Stitched divider -->
  <div class="h-px mx-auto max-w-2xl border-t-2 border-dashed border-primary/30 animate-stitch"></div>
</section>
