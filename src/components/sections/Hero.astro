---
import Button from '@components/ui/Button.astro';
import { SITE, SOCIALS } from '@lib/constants';
---

<section class="relative overflow-hidden bg-gradient-to-b from-cream via-surface to-background" aria-label="Welcome to Faithfully Crafted">
  <!-- Decorative floating elements -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Yarn ball top-right -->
    <svg
      class="absolute -top-4 right-8 w-20 h-20 text-mint/30 animate-float hidden sm:block"
      viewBox="0 0 80 80"
      fill="currentColor"
    >
      <circle cx="40" cy="40" r="35" />
      <path d="M20 50c10-15 20-20 25-35M30 20c5 15 15 25 30 30" stroke="white" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.5" />
    </svg>
    <!-- Bow left -->
    <svg
      class="absolute top-1/3 -left-2 w-14 h-14 text-primary/20 animate-float-delayed hidden lg:block"
      viewBox="0 0 56 56"
      fill="currentColor"
    >
      <path d="M28 28c-8-8-20-12-20-4s12 12 20 4zm0 0c8-8 20-12 20-4s-12 12-20 4z" />
      <circle cx="28" cy="28" r="4" />
    </svg>
    <!-- Small stars -->
    <svg
      class="absolute bottom-1/4 right-1/4 w-6 h-6 text-gold/40 animate-pulse-soft"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d="M12 0L14 9L24 12L14 14L12 24L10 14L0 12L10 9Z" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16 sm:pt-36 sm:pb-20 lg:pt-48 lg:pb-28">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
      <!-- Text Content -->
      <div class="flex-1 text-center lg:text-left">
        <h1
          class="font-brand text-primary-bold leading-tight"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
        >
          {SITE.name}
        </h1>
        <p
          class="mt-4 font-heading text-text-muted leading-relaxed max-w-lg mx-auto lg:mx-0"
          style="font-size: clamp(1.1rem, 2vw, 1.35rem);"
        >
          {SITE.tagline}
        </p>
        <p class="mt-3 text-text-muted/80 max-w-md mx-auto lg:mx-0">
          Beautiful handmade crochet pieces — amigurumi, accessories, and heartfelt gifts, crafted
          by Faith from the Philippines.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
          <Button href="/gallery/" variant="primary" size="lg">
            View Gallery
          </Button>
          <Button href={SOCIALS.facebook.messenger} variant="secondary" size="lg" external>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.373 0 0 4.974 0 11.111c0 3.498 1.744 6.614 4.469 8.654V24l4.088-2.242c1.092.3 2.246.464 3.443.464 6.627 0 12-4.975 12-11.111S18.627 0 12 0z" />
            </svg>
            Message Me
          </Button>
        </div>
      </div>

      <!-- Decorative Mascot Area -->
      <div class="flex-shrink-0 relative" data-reveal="scale">
        <div class="w-full max-w-sm mx-auto group perspective-1000">
          <div class="relative w-64 sm:w-80 lg:w-96 mx-auto">
            <!-- Decorative background layers -->
            <div class="absolute inset-0 bg-primary/20 rounded-3xl translate-x-3 translate-y-3 sm:translate-x-5 sm:translate-y-5 rotate-3 transition-transform duration-500 ease-out group-hover:translate-x-6 group-hover:translate-y-6 group-hover:rotate-6 shadow-sm"></div>
            <div class="absolute inset-0 bg-gold/20 rounded-3xl -translate-x-2 -translate-y-2 sm:-translate-x-4 sm:-translate-y-4 -rotate-2 transition-transform duration-500 ease-out group-hover:-translate-x-5 group-hover:-translate-y-5 group-hover:-rotate-4 shadow-sm"></div>
            
            <!-- Main Photo Frame -->
            <div class="relative w-full bg-body p-3 sm:p-5 rounded-3xl shadow-xl shadow-primary/10 rotate-[2deg] transition-transform duration-500 ease-out group-hover:rotate-0 border border-surface flex flex-col z-10 box-border bg-white">
              <!-- Diagonal Washi Tape -->
              <div class="absolute -top-4 right-8 w-24 h-6 bg-lavender/60 border border-white/40 shadow-sm rotate-[10deg] z-20 backdrop-blur-md opacity-90" style="clip-path: polygon(4% 5%, 96% 2%, 98% 95%, 2% 98%);"></div>

              <!-- Picture -->
              <div class="relative aspect-square sm:aspect-square rounded-2xl overflow-hidden bg-surface shadow-inner">
                <img
                  src="/faith.jpg"
                  alt="Crafting pieces by Faith"
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading="eager"
                />
                <div class="absolute inset-0 border border-black/5 rounded-2xl pointer-events-none mix-blend-overlay"></div>
              </div>
              
              <!-- Frame Caption -->
              <div class="pt-5 pb-2 text-center pointer-events-none">
                <span class="font-brand text-3xl sm:text-4xl text-primary-bold/90 drop-shadow-sm">by Faith</span>
              </div>
            </div>
          </div>
        </div>
        <!-- Floating mini yarn balls -->
        <div class="absolute -top-4 -right-4 w-10 h-10 bg-mint/40 rounded-full animate-float"></div>
        <div class="absolute -bottom-2 -left-4 w-8 h-8 bg-lavender/40 rounded-full animate-float-delayed"></div>
      </div>
    </div>
  </div>

  <!-- Stitched divider -->
  <div class="h-px mx-auto max-w-2xl border-t-2 border-dashed border-primary/30 animate-stitch"></div>
</section>
