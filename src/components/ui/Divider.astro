---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`flex items-center justify-center gap-3 py-8 ${className}`} aria-hidden="true">
  <svg class="w-4 h-4 text-primary opacity-60" viewBox="0 0 16 16" fill="currentColor">
    <circle cx="5" cy="11" r="3" />
    <circle cx="10" cy="7" r="2.5" />
    <circle cx="13" cy="11" r="1.5" />
  </svg>
  <div class="h-px w-16 bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>
  <svg class="w-3 h-3 text-lavender opacity-60" viewBox="0 0 12 12" fill="currentColor">
    <path d="M6 0L7.5 4.5L12 6L7.5 7.5L6 12L4.5 7.5L0 6L4.5 4.5Z" />
  </svg>
  <div class="h-px w-16 bg-gradient-to-r from-transparent via-primary/40 to-transparent"></div>
  <svg class="w-4 h-4 text-mint opacity-60" viewBox="0 0 16 16" fill="currentColor">
    <circle cx="8" cy="8" r="6" />
    <path d="M5 10c1-2 2.5-3 3-5M8 5c1 2 2 3 3 5" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" />
  </svg>
</div>
